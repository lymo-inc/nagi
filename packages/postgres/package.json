{
  "name": "@nagi-js/postgres",
  "version": "0.1.1-rc.1",
  "description": "Postgres Store adapter for nagi (Kysely-shaped).",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "nagi",
    "workflow",
    "postgres",
    "kysely",
    "durable",
    "store",
    "adapter"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": false
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@nagi-js/core": "workspace:*"
  },
  "peerDependencies": {
    "kysely": "^0.28.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "kysely": "^0.28.0",
    "pg": "^8.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lymo-inc/nagi.git",
    "directory": "packages/postgres"
  },
  "homepage": "https://github.com/lymo-inc/nagi#readme",
  "bugs": {
    "url": "https://github.com/lymo-inc/nagi/issues"
  }
}
