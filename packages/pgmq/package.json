{
  "name": "@nagi-js/pgmq",
  "version": "0.0.0",
  "description": "PGMQ Queue adapter for nagi.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nagi-js/core": "workspace:*"
  },
  "peerDependencies": {
    "kysely": "^0.28.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lymo-inc/nagi.git",
    "directory": "packages/pgmq"
  },
  "homepage": "https://github.com/lymo-inc/nagi#readme",
  "bugs": {
    "url": "https://github.com/lymo-inc/nagi/issues"
  }
}
