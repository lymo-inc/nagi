{
  "name": "nagi-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Type-safe declarative workflow library for TypeScript.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "^2.27.10",
    "publint": "^0.2.12",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
